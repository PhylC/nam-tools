NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional override for Supabase password reset emails.
# If unset, the app uses the current browser origin, e.g. http://localhost:3000/update-password locally
# and https://accountplanningtools.co.uk/update-password or https://accountplanningtools.com/update-password on the live domain.
NEXT_PUBLIC_PASSWORD_RESET_REDIRECT_URL=

RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@accountplanningtools.co.uk
CONTACT_FROM_EMAIL=hello@accountplanningtools.co.uk

# Temporary development/testing toggle. When true, it shows only for signed-in users.
# Remove once Stripe-backed plan detection is live.
NEXT_PUBLIC_SHOW_PLAN_TOGGLE=false
